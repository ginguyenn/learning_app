output$coin_plot <- renderPlot({
target_n <- input_number
set.seed(target_n)
result <- sample(c(0,1), size = target_n, replace = TRUE, prob = c(0.5,0.5))
cum_sum <- cumsum(result)
trials<- 1/ target_n
rel_freq <- cum_sum/trials
plot_data <- data_frame(Trials = trials, RelFreg = rel_freq)
})
