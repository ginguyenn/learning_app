htmltools::img(src="www/Beziehung.png", width ="100%", style ="max-width:500px")
tabsetPanel(
type = "tabs",
# --- TAB 1: PERMUTATION ---
tabPanel("Permutation",
br(),
h2("Permutation"),
p("Eine Menge mit $n$ Elementen. Jede Anordnung dieser Elemente in einer bestimmten Reihenfolge heißt ", strong("Permutation"), " dieser Elemente. Bei Permutation unterscheidet man 2 Fälle:"),
tags$ul(
tags$li(strong("Permutationen ohne Wiederholung:"), " Sind alle $n$ Elemente unterscheidbar (z.B: 3 Bücher (A, B, C) legen in einem Buchregal, jedes Buch ist einzigartig)."),
tags$li(strong("Permutationen mit Wiederholung:"), " Sind einige Elemente gleich (z.B 100 HTW-Studierende werden in 2 Gruppen aufgeteilt: Bachelor und Master, egal was ihre Namen oder Geschlechte sind, solange bleiben die Studierenden innerhalb der Master-Gruppe, die sind gleich).")
),
hr(),
h3("1.1 Permutation ohne Wiederholung"),
p("Alle Elemente sind verschieden/unterscheidbar, dann gibt es $n!$ verschiedene Anordnungen. $n!$ heißt ", em("n Fakultät"), " mit $n \\geq 0$."),
p("$1! = 1$"),
p("$2! = 2 \\cdot 1 = 2$"),
p("$3! = 3 \\cdot 2 \\cdot 1 = 6$"),
p("$4! = 4 \\cdot 3 \\cdot 2 \\cdot 1 = 24$"),
h4("Beispiele:"),
tags$ol(
tags$li(
p("Du hast 5 verschiedene Bücher und möchtest wissen, wie viele Arten kannst Du diese in einem Regal anordnen:"),
p("Anzahl der Bücher: $n = 5 \\implies n! = 5! = 120$ Möglichkeiten.")
),
tags$li(
p("Acht verschiedene Personen sollen sich beliebig auf acht Stühle verteilen. Wie viele Möglichkeiten zur Anordnung der Personen gibt es?"),
p("Anzahl der Personen: $n = 8 \\implies n! = 8! = 40.320$ Möglichkeiten.")
),
tags$li(
p("3 Kinder (A,B,C) stellen sich an einem Eisstand an. Wie viele Möglichkeiten des Anstehens?"),
p("Anzahl der Kinder: $n = 3 \\implies n! = 3! = 6$ Möglichkeiten.")
)
),
h4("Zyklische Permutation"),
p("Es gibt $(n-1)!$ Möglichkeiten, unterscheidbare Objekte in einem Kreis anzuordnen."),
p("In einer Urne befinden sich 5 verschiedenfarbige Kugeln. Wie viele Möglichkeiten gibt es, die Kugeln ", em("in einer Reihe"), " anzuordnen?"),
p("$n! = 5! = 120$"),
p("Wie viele Möglichkeiten gibt es, die Kugeln ", em("in einem Kreis"), " anzuordnen?"),
p("$(n-1)! = (5-1)! = 4! = 24$"),
hr(),
h3("1.2 Permutation mit Wiederholung"),
p("Eine Permutation mit Wiederholung ist eine Anordnung von $n$ Objekten, von denen manche nicht unterscheidbar sind."),
p("$$\\frac{n!}{k_1! \\cdot k_2! \\cdots k_m!}$$"),
p("$n$: Gesamtzahl der Objekte"),
p("$k$: Gesamtzahl der identischen Objekte"),
h4("Beispiele:"),
tags$ol(
tags$li(
p("Ein Korb enthält 3 Äpfel und 2 Bananen, wie viele Möglichkeiten gibt es, diese Obst in einer Reihe anzuordnen?"),
p("$n=5$ (3 Äpfel + 2 Bananen), $k_1 = 3$ (Apfel), $k_2 = 2$ (Banane)"),
p("$$\\frac{5!}{3! \\cdot 2!} = 10 \\text{ Möglichkeiten.}$$")
),
tags$li(
p("Du möchtest die Buchstaben des Wortes 'BANANA' anordnen, wie viele Möglichkeiten gibt es?"),
p("$n=6$, $k_1 = 1$ (B), $k_2 = 3$ (A), $k_3 = 2$ (N)"),
p("$$\\frac{6!}{1! \\cdot 2! \\cdot 3!} = 60 \\text{ Möglichkeiten.}$$")
)
)
),
# --- TAB 2: VARIATION ---
tabPanel("Variation",
br(),
h2("Variation"),
p("Die Variation handelt sich um eine Auswahl von $k$ Elementen, bzw. ein Teil einer Grundmenge von $n$ Elementen, bei der die Reihenfolge eine Rolle spielt."),
blockquote("Warum ist die Reihenfolge bei der Variation wichtig? Stell dir vor, một mã PIN 4 số từ 0 đến 9 được chọn. Nhập '1234' thì mở khóa, nhập '4321' thì báo lỗi. Rõ ràng thứ tự thay đổi tạo ra kết quả mới."),
p(strong("Identifizierungstipp:"), " Jede Aufgabe, die Rangfolge (Erster, Zweiter, Dritter), Rollenzuweisung (Bachelor, Master) oder Identifikationsnummer (PIN-Code, ID-Nummer, Handynummer) beinhaltet, ist eine Variationsaufgabe."),
p("Der Unterschied zwischen mit und ohne Wiederholung liegt auf eine Aktion: ob die ausgewählte Elemente im nächsten Zug erneut ausgewählt werden oder nicht."),
hr(),
h3("2.1 Variation mit Wiederholung"),
p("Die Elemente dürfen wieder verwendet werden und die Elemente im Ergebnis können exakt gleich sein."),
p("$$n^k$$"),
h4("Beispiel:"),
p("Ein Smartphone-PIN besteht aus 4-stelligen Nummerkombination (Ziffern von 0 bis 9)."),
p("$n=10, k=4 \\implies n^k = 10^4 = 10.000$ Möglichkeiten."),
hr(),
h3("2.2 Variation ohne Wiederholung"),
p("Die gezogenen Elemente werden nicht zurückgelegt."),
p("$$\\frac{n!}{(n-k)!}$$"),
h4("Beispiel:"),
p("In einem Pferderennen hat 20 Pferde. 3 Pferde werden vorausgenommen, die als Erstes, Zweites und Drittes kommen."),
p("$n=20, k=3 \\implies \\frac{20!}{(20-3)!} = 6.840$ Möglichkeiten.")
),
# --- TAB 3: KOMBINATION ---
tabPanel("Kombination",
br(),
h2("Kombination"),
p("Die Kombination handelt sich um eine Auswahl von $k$ Elementen, bei der die Reihenfolge ", em("keine"), " Rolle spielt (z.B. Obstkorb mit Orange, Apfel, Mango)."),
p(strong("Identifizierungstipp:"), " Jede Aufgabe, bei der es nur um eine Auswahl oder Gruppenbildung geht (z.B. Lotto, Teambildung...), ohne dass die Positionen der Elemente eine Rolle spielen."),
hr(),
h3("3.1 Kombination ohne Wiederholung"),
p("Die gezogenen Elemente werden nicht zurückgelegt."),
p("$$\\binom{n}{k} = \\frac{n!}{k!(n-k)!}$$"),
h4("Beispiel:"),
p("Die Ziehung von Lotto '6 aus 49'."),
p("$n=49, k=6 \\implies \\binom{49}{6} = 13.983.816$ Möglichkeiten."),
hr(),
h3("3.2 Kombination mit Wiederholung"),
p("Die Elemente dürfen wieder verwendet werden."),
p("$$\\binom{n+k-1}{k}=\\frac{(n+k-1)!}{(n-1)! \\cdot k!}$$"),
h4("Beispiel:"),
p("4 kleine Welpen suchen sich einen Platz unter einem der 6 Stühle."),
p("$n=6, k=4 \\implies \\frac{(6+4-1)!}{(6-1)! \\cdot 4!} = 126$ Möglichkeiten.")
)
)
