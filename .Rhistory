input$roll_btn
if (input$roll_btn == 0) return(NULL)
# create random results from 1 to 6
res <- sample(1:6, 1)
img_list <- c(
"www/dice 1.png",
"www/dice 2.png",
"www/dice 3.png",
"www/dice 4.png",
"www/dice 5.png",
"www/dice 6.png")
