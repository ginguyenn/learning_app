# Install thematic and un-comment for themed static plots (i.e., ggplot2)
# thematic::thematic_rmd()
#import data
titanic <- read.csv("titanic_data.csv")
fare_mean <- mean(titanic$Fare, na.rm = TRUE) #giûÀ trÃ£ na bÃ£ loÃ¤Ài bÃ£
fare_std <- sd(titanic$Fare, na.rm = TRUE)
fare_med <- median(titanic$Fare, na.rm = TRUE)
#Graph
ggplot(titanic, aes(x= Fare))+
geom_density(fill="tan")+
geom_vline(xintercept = fare_mean, color= "blue", size =1)+
geom_vline(xintercept = fare_std, color="orange", size =1)+
geom_vline(xintercept = fare_med, color="red", linetype="dashed", size =1)+ #dashed: line nûˋt áÃ£ˋt
theme_bw()+
labs(x = "",
title = "Fare Distribution")+
#note cÃ£Ïa line
annotate("text", x = fare_mean, y = 0.02, label = "Mean", color = "blue", vjust = -0.5, size = 4) +
annotate("text", x = fare_std, y = 0.02, label = "Standard Deviation", color = "orange", vjust = -0.5, size = 4) +
annotate("text", x = fare_med, y = 0.02, label = "Median", color = "red", vjust = -0.5, size = 4)
#Survival Rate by Fare
ggplot(titanic, aes(x = fare_group, fill = Survived)) +
geom_bar() +
theme_bw() +
labs(x = "Fare Group", y = "Passenger Count", title = "Survival Rate by Fare Group")+
scale_fill_manual(values = c("0" = "gold", "1" ="maroon"))
ggplot(titanic, aes(x = titanic$fam_size, fill = Survived))+
theme_bw()+
geom_bar()+
labs(x = "Family Size",
y =" Passenger Count",
title = "Survival Rate by Family Size")+
scale_fill_manual(values = c("0"= "tomato1", "1"= "royalblue2"))
