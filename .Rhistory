next_id <- reactiveVal(5)
observeEvent(input$add_c, {
if (nrow(pool_data()) >= 12) return()
nid <- next_id()
pool_data(rbind(pool_data(), data.frame(id = nid, category = "Coffee", name = "Coffee", code = paste0("C", nid), bg = "#ea580c", stringsAsFactors = FALSE)))
next_id(nid + 1)
})
observeEvent(input$add_t, {
if (nrow(pool_data()) >= 12) return()
nid <- next_id()
pool_data(rbind(pool_data(), data.frame(id = nid, category = "Tea", name = "Tea", code = paste0("T", nid), bg = "#16803d", stringsAsFactors = FALSE)))
next_id(nid + 1)
})
observeEvent(input$add_b, {
if (nrow(pool_data()) >= 12) return()
nid <- next_id()
pool_data(rbind(pool_data(), data.frame(id = nid, category = "Bakery", name = "Bakery", code = paste0("B", nid), bg = "#b45309", stringsAsFactors = FALSE)))
next_id(nid + 1)
})
observeEvent(input$remove_item_id, {
df <- pool_data()
if (nrow(df) <= 1) return()
pool_data(df[df$id != as.numeric(input$remove_item_id), ])
})
output$pool_display <- renderUI({
df <- pool_data()
buttons <- lapply(1:nrow(df), function(i) {
tags$div(
style = paste0("display: inline-block; padding: 6px 12px; margin: 4px; font-weight: 600; font-size: 12px; border-radius: 8px; color: white; border: 1px solid rgba(0,0,0,0.1); cursor: pointer; background-color: ", df$bg[i], ";"),
onclick = paste0("Shiny.setInputValue('remove_item_id', ", df$id[i], ", {priority: 'event'});"),
HTML(paste0(df$name[i], " <sub>", df$id[i], "</sub>"))
)
})
do.call(tags$div, c(list(style = "display: flex; flex-wrap: wrap; gap: 4px; padding: 15px; background: #ffffff; border: 1px solid #e5e7eb; border-radius: 8px;"), buttons))
})
fluidPage(
theme = NULL,
# Tiêu đề chương
div(style = "border-bottom: 1px solid #e5e7eb; padding-bottom: 10px; margin-bottom: 20px;",
h3("Wahrscheinlichkeiten von mehreren Ereignissen", style = "font-weight: 700; color: #111827; margin: 0;")
),
# Grid Workspace giống bản HTML gốc
fluidRow(
# LEFT PANEL: Định nghĩa & Parameter
column(5,
# Khối 1: Thống kê không gian mẫu thực tế
div(style = "background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 12px; padding: 15px; margin-bottom: 15px;",
div(style = "display: flex; flex-col: vertical; gap: 8px;",
div(style = "display: flex; justify-content: space-between; align-items: center; background: white; border: 1px solid #e5e7eb; padding: 10px; border-radius: 8px; font-size: 12px;",
span("Ereignis A: Coffee:"),
span("58.416 / 149.116", style = "font-family: monospace; color: #ea580c; font-weight: bold; background: #fff7ed; padding: 2px 8px; border-radius: 4px;")
),
div(style = "display: flex; justify-content: space-between; align-items: center; background: white; border: 1px solid #e5e7eb; padding: 10px; border-radius: 8px; font-size: 12px; margin-top: 6px;",
span("Ereignis B: Large:"),
span("44.885 / 149.116", style = "font-family: monospace; color: #ea580c; font-weight: bold; background: #fff7ed; padding: 2px 8px; border-radius: 4px;")
),
div(style = "display: flex; justify-content: space-between; align-items: center; background: white; border: 1px solid #e5e7eb; padding: 10px; border-radius: 8px; font-size: 12px; margin-top: 6px;",
span("Schnittmenge (A ∩ B): Kaffee & Lg:"),
span("16.590 / 149.116", style = "font-family: monospace; color: #ea580c; font-weight: bold; background: #fff7ed; padding: 2px 8px; border-radius: 4px;")
)
)
),
# Khối 2: Cấu hình kích thước mẫu mô phỏng (n)
div(style = "background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 12px; padding: 15px; margin-bottom: 15px;",
div(style = "display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;",
p(strong("Anzahl der Kunden"), style = "font-size: 11px; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin: 0;"),
span(style = "font-size: 12px; font-weight: 700; color: #ea580c; background: #fff7ed; padding: 2px 8px; border-radius: 6px;",
textOutput("label_n_val", inline = TRUE))
),
sliderInput("slider_n", label = NULL, min = 1, max = 500, value = 12, step = 1, width = "100%")
),
# Khối 3: Bộ chọn phép toán tập hợp
div(style = "background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 12px; padding: 15px;",
p(strong("Mengenoperation / Rechenregel auswählen"), style = "font-size: 11px; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;"),
selectInput("model_select", label = NULL,
choices = c("1. Schnittmenge: P(A ∩ B) [Kaffee UND Large]" = "ops_schnitt",
"2. Additionssatz: P(A ∪ B) [Kaffee ODER Large]" = "ops_verein",
"3. Differenzmenge: P(A \\ B) [Kaffee, aber NICHT Large]" = "ops_diff",
"4. de Morgan 1: P((A ∪ B)ᶜ) [Weder Kaffee noch Large]" = "ops_morgan1",
"5. de Morgan 2: P((A ∩ B)ᶜ) [Nicht gleichzeitig Kaffee & Lg]" = "ops_morgan2"),
selected = "ops_schnitt", width = "100%")
)
),
# RIGHT PANEL: Hiển thị Công thức & Kết quả Real-time
column(7,
# Khối hiển thị động thông tin công thức toán học
uiOutput("formula_info_box"),
# Khối hiển thị danh sách khách hàng mô phỏng live
div(style = "background: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 15px;",
div(style = "display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #e5e7eb; padding-bottom: 10px; margin-bottom: 12px;",
div(style = "font-weight: 700; font-size: 12px; color: #374151; text-transform: uppercase; letter-spacing: 0.05em;",
HTML("<i class='fa-solid fa-square-poll-horizontal' style='color:#ea580c; margin-right:5px;'></i> Empirische Live-Simulation")
),
span(style = "font-size: 11px; background: #dcfce7; padding: 4px 10px; border-radius: 6px; color: #166534; font-weight: 600; border: 1px solid #bbf7d0;",
"Trefferquote: ", strong(textOutput("hit_rate_text", inline = TRUE), style = "color: #15803d;"))
),
# Khung cuộn chứa danh sách thẻ khách hàng giống HTML gốc
uiOutput("outcomes_scroll_grid"),
div(style = "margin-top: 12px; font-size: 11px; color: #9ca3af; font-weight: 500; display: flex; align-items: center; gap: 6px;",
HTML("<i class='fa-solid fa-circle-info' style='color:#ea580c;'></i> Farbige Karten zeigen an, welche simulierten Kunden das gewählte Ereignismuster erfüllen.")
)
)
)
)
)
quiz(
question(
"Was beschreibt die 'A-priori-Wahrscheinlichkeit' $P(A)$ im Kontext des Satzes von Bayes?",
answer("Die aktualisierte Wahrscheinlichkeit nach dem Eintreffen neuer Daten."),
answer("Die Grundwahrscheinlichkeit eines Ereignisses vor dem Vorliegen neuer Belege oder Informationen.", correct = TRUE),
answer("Die Wahrscheinlichkeit, dass ein Fehler in der Berechnung vorliegt."),
answer("Die Schnittmenge zweier völlig stochastisch unabhängiger Ereignisse."),
allow_retry = TRUE,
message = "Die A-priori-Wahrscheinlichkeit (Vorwissen) ist die Ausgangswahrscheinlichkeit eines Ereignisses, bevor neue Befunde oder Testergebnisse berücksichtigt werden."
),
question(
"Welche Wahrscheinlichkeit wird als 'A-posteriori-Wahrscheinlichkeit' bezeichnet?",
answer("$P(A)$"),
answer("$P(B | A)$"),
answer("$P(A | B)$", correct = TRUE),
answer("$P(B)$"),
allow_retry = TRUE,
message = "$P(A | B)$ ist die A-posteriori-Wahrscheinlichkeit – also die aktualisierte Wahrscheinlichkeit des Ereignisses A unter der Bedingung, dass das Ereignis B bereits eingetreten ist."
),
question(
"Wie lautet die mathematische Formel für den Satz von Bayes zur Berechnung von $P(A | B)$?",
answer("$P(A | B) = \\frac{P(B | A) \\cdot P(A)}{P(B)}$", correct = TRUE),
answer("$P(A | B) = P(A) \\cdot P(B)$"),
answer("$P(A | B) = \\frac{P(B | A)}{P(A)}$"),
answer("$P(A | B) = P(A \\cap B) \\cdot P(B)$"),
allow_retry = TRUE,
message = "Der Satz von Bayes lautet: $P(A | B) = \\frac{P(B | A) \\cdot P(A)}{P(B)}$. Dabei ist der Zähler die Schnittmenge $P(B \\cap A)$ und der Nenner die Gesamtwahrscheinlichkeit $P(B)$."
),
question(
"Was steht im Nenner des Satzes von Bayes, wenn man die totale Wahrscheinlichkeit für $P(B)$ einsetzt?",
answer("$P(B | A) \\cdot P(A)$"),
answer("$P(B | A) \\cdot P(A) + P(B | \\neg A) \\cdot P(\\neg A)$", correct = TRUE),
answer("$P(A | B) + P(A | \\neg B)$"),
answer("$1 - P(B)$"),
allow_retry = TRUE,
message = "Der Nenner $P(B)$ wird über die Formel der totalen Wahrscheinlichkeit als Summe der bedingten Pfade berechnet: $P(B | A) \\cdot P(A) + P(B | \\neg A) \\cdot P(\\neg A)$."
),
question(
"Gegeben sind $P(\\text{Kaffee}) = 0.60$, $P(\\text{Gebäck} | \\text{Kaffee}) = 0.20$ und $P(\\text{Gebäck} | \\text{Kein Kaffee}) = 0.10$. Wie hoch ist die Gesamtwahrscheinlichkeit für den Kauf von Gebäck, $P(\\text{Gebäck})$?",
answer("0.12"),
answer("0.04"),
answer("0.16", correct = TRUE),
answer("0.30"),
allow_retry = TRUE,
message = "$P(\\text{Gebäck}) = (0.20 \\cdot 0.60) + (0.10 \\cdot 0.40) = 0.12 + 0.04 = 0.16$ (bzw. 16%)."
),
question(
"Nutzen Sie die Werte aus der vorherigen Frage: $P(\\text{Kaffee}) = 0.60$, $P(\\text{Gebäck} | \\text{Kaffee}) = 0.20$, $P(\\text{Gebäck}) = 0.16$. Wie hoch ist $P(\\text{Kaffee} | \\text{Gebäck})$ nach dem Satz von Bayes?",
answer("25.00%"),
answer("75.00%", correct = TRUE),
answer("50.00%"),
answer("12.00%"),
allow_retry = TRUE,
message = "$P(\\text{Kaffee} | \\text{Gebäck}) = \\frac{P(\\text{Gebäck} | \\text{Kaffee}) \\cdot P(\\text{Kaffee})}{P(\\text{Gebäck})} = \\frac{0.20 \\cdot 0.60}{0.16} = \\frac{0.12}{0.16} = 0.75$ oder 75%."
),
question(
"Warum wird der Satz von Bayes oft auch als 'Rückwärts-Logik' bezeichnet?",
answer("Weil er mathematisch von hinten nach vorne aufgeschrieben wird."),
answer("Weil man von einer beobachteten Wirkung (B) rückwärts auf deren wahrscheinliche Ursache (A) schließt.", correct = TRUE),
answer("Weil das Ergebnis immer kleiner als die Ausgangswahrscheinlichkeit sein muss."),
answer("Weil er nur für negative Korrelationen angewendet werden darf."),
allow_retry = TRUE,
message = "Es ist eine Rückwärts-Logik, da wir die Wahrscheinlichkeit einer Ursache (z. B. eine bestimmte Bestellung) aktualisieren, nachdem wir den Effekt oder das Merkmal (z. B. Kauf eines Zusatzprodukts) bereits beobachtet haben."
),
question(
"Was passiert mit $P(A | B)$, wenn die A-priori-Wahrscheinlichkeit $P(A)$ bei gleichbleibenden Bedingungen steigt?",
answer("P(A | B) sinkt."),
answer("P(A | B) bleibt exakt identisch."),
answer("P(A | B) steigt ebenfalls.", correct = TRUE),
answer("P(A | B) fällt sofort auf 0."),
allow_retry = TRUE,
message = "Da $P(A)$ direkt proportional im Zähler der Bayes-Formel steht, führt eine höhere A-priori-Wahrscheinlichkeit (höheres Vorwissen) tendenziell auch zu einer höheren A-posteriori-Wahrscheinlichkeit."
),
question(
"Ein medizinischer Test hat eine Sensitivität von 90% ($P(\\text{Positiv} | \\text{Krank})$) und eine Spezifität von 90% ($P(\\text{Negativ} | \\text{Gesund})$). Wenn die Krankheit sehr selten ist ($P(\\text{Krank}) = 1\\%$), wie verhält sich die A-posteriori-Chance bei einem positiven Testergebnis?",
answer("Sie liegt sehr nah bei 100%, da der Test sehr sicher ist."),
answer("Sie bleibt trotz des positiven Tests überraschend niedrig, da die geringe Basisrate den Nenner dominiert.", correct = TRUE),
answer("Sie fällt auf exakt 0%."),
answer("Sie entspricht genau der Sensitivität von 90%."),
allow_retry = TRUE,
message = "Das ist das klassische Bayes-Paradoxon: Bei einer sehr kleinen Basisrate (A-priori-Wahrscheinlichkeit) ist die Wahrscheinlichkeit, trotz positivem Test tatsächlich krank zu sein, oft erstaunlich gering, da es absolut gesehen viele falsch-positive Ergebnisse gibt."
),
question(
"Wenn $P(B | A)$ exakt gleich $P(B | \\neg A)$ ist, was lässt sich dann über $P(A | B)$ sagen?",
answer("P(A | B) ist unendlich groß."),
answer("P(A | B) ist genau gleich der A-priori-Wahrscheinlichkeit $P(A)$, da das Ereignis B keine neuen Informationen liefert.", correct = TRUE),
answer("P(A | B) ist immer 0."),
answer("Die Bayes-Formel ist in diesem Fall mathematisch nicht definiert."),
allow_retry = TRUE,
message = "Wenn $P(B | A) = P(B | \\neg A)$, sind die Ereignisse stochastisch unabhängig. Das Eintreffen von B ändert nichts an der Wahrscheinlichkeit von A, weshalb $P(A | B) = P(A)$ gilt."
)
)
