server <- function(input, output) {
coffee_data <- read.csv2("data/coffee.csv")
# Logic mô phỏng: Tính xác suất thực tế từ dữ liệu
prob_coffee <- reactive({
sum(coffee_data$product_category == "Coffee") / nrow(coffee_data)
})
sim_data <- eventReactive(input$run_sim, {
set.seed(123)
# Mô phỏng Bernoulli với xác suất thực tế
rbinom(input$n_customers, 1, prob_coffee())
})
output$coffee_plot <- renderPlot({
req(sim_data())
n <- input$n_customers
cum_mean <- cumsum(sim_data()) / (1:n)
df <- data.frame(n = 1:n, mean = cum_mean)
ggplot(df, aes(x = n, y = mean)) +
geom_line(color = "#e65c00", size = 1) +
geom_hline(yintercept = prob_coffee(), linetype = "dashed", color = "#4a2711") +
theme_minimal() +
labs(x = "Số lượng khách", y = "Tỷ lệ mua Cà phê")
})
output$stats_info <- renderText({
paste("Xác suất thực tế từ dữ liệu:", round(prob_coffee() * 100, 2), "%")
})
}
