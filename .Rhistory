quiz( caption = "Übung",
question("Wie lassen sich Wahrscheinlichkeiten darstellen?(Es können mehrere Antworten richtig sein)",
answer("Prozentangabe", correct = TRUE),
answer("Bruch", correct = TRUE),
answer("Dezimalzahl", correct = TRUE),
allow_retry = TRUE
),
question ("Ein Würfel wird einmal geworfen. Wie hoch ist die Wahrscheinlichkeit, eine Zahl größer als 4 (5 oder 6) aufzutauchen",
answer("$\\frac{1}{6}$"),
answer("$\\frac{1}{3}$", correct = TRUE),
answer("$\\frac{1}{2}$"),
allow_retry = TRUE
),
question("$P(A) = \\frac{|A|}{...}$",
answer("$A$"),
answer("$\\omega$"),
answer("$\\Omega$", correct=TRUE),
allow_retry = TRUE
),
question("In der HTW Mensa verkäuft Cola, Pepsi, Kuchen, Suppe, Mittagsessen. <br> $A$= {Suppe, Cola}. <br> $A^c$ = ?",
answer("Alle"),
answer("Pepsi, Cola, Suppe"),
answer("Pepsi, Kuchen, Mittagsessen", correct = TRUE),
allow_retry = TRUE),
question("Welche Aussage ist korrekt?",
answer("Die Wahrscheinlichkeit können mehr 100% erreichen, wenn der Datensatz zu groß ist."),
answer("In einem Laplace-Raum beträgt die Wahrscheinlichkeit gleiche Chance", correct = TRUE),
answer("Je niedriger die Wahrscheinlichkeit ist, desto größer den Datensatz"),
allow_retry = TRUE
),
question("Angenommen, Dein Coffee-Shop hat heute 0 Bestellungen ($|\\Omega$|) = 0$, weil Feiertag ist, Wie wird die Wahrscheinlichkeit für den Verkauf eines Tee berechnet?",
answer("Nicht definiert, weil man nicht durch $|\\Omega$| teilen kann", correct = TRUE),
answer("$\\frac{1}{9}$"),
answer("0%"),
allow_retry = TRUE),
question("Was beschreibt die Striche im Nenner der Formel $|\\Omega|$",
answer("Ein absoluten Betrag, um negative Wahrscheinlichkeit zu vermeiden."),
answer("Die absolute Anzahl aller Elemente, die im Graundraum enthalten sind.",correct = TRUE),
answer("Die Striche darstellen einen leeren Grundraum")),
question("Wie hoch ist die Wahrscheinlichkeit für den Kauf von Coffee am Wochenende?",
answer("$\\frac{1}{9}$, weil jede Bestellung unabhängig ist.", correct = TRUE),
answer("Höher als $\\frac{1}{9}$, weil Coffee am liebsten ist und am höchsten realen Wahrscheinlichkeit im Datensatz hat."),
answer("Extrem niedrig, weil tatsächlich man am Wochenende nicht arbeiten muss und man braucht nicht wach sein."))
)
