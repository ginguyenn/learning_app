)))
cor(pruef, vorb)
#Aufgabe 2
pruef <- c(1,1,2,2,2,4,4,4,5,5)
vorb <- c(4,5,1,,1,2,1,1,2,4,5)
cor(pruef, vorb)
#Aufgabe 2
pruef <- c(1,1,2,2,2,4,4,4,5,5)
vorb <- c(4,5,1,,1,2,1,1,2,4,5)
vorb <- c(4,5,1,1,2,1,1,2,4,5)
cor(pruef, vorb)
