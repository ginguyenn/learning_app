plot_data <- data.frame(
Trials = trials,
RelFrequency = rel_freq
)
ggplot(plot_data, aes(x = Trials, y = RelFrequency))+
geom_line(color = "orange", linewidth = 1)+
#expect value line
geom_hline(yintercept = true_prob, linetype = "dashed", color="#4A2711", linewidth =0.8)+
scale_y_continuous(labels = scales::percent_format(accuracy = 1), limits = c(0.1,0.7))+
scale_x_continuous(labels = scales::label_comma(big.mark = ".")) +
labs(
title = "Konvergenz der relativen Häufigkeit (Kategorie: Coffee)",
subtitle = paste0("Das Gesetz der großen Zahlen: Stabilisierung bei ca. ", round(true_prob*100,2), "%"),
x= "Anzahl der Bestellungen (N)",
y="Relative Häufigkeit")
})
