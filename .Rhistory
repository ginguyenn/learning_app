p(strong("Identifizierungstipp:"), " Jede Aufgabe, bei der es nur um eine Auswahl oder Gruppenbildung geht (z.B. Lotto, Teambildung...), ohne dass die Positionen der Elemente eine Rolle spielen."),
hr(),
h3("3.1 Kombination ohne Wiederholung"),
p("Die gezogenen Elemente werden nicht zurückgelegt."),
p("$$\\binom{n}{k} = \\frac{n!}{k!(n-k)!}$$"),
h4("Beispiel:"),
p("Die Ziehung von Lotto '6 aus 49'."),
p("$n=49, k=6 \\implies \\binom{49}{6} = 13.983.816$ Möglichkeiten."),
hr(),
h3("3.2 Kombination mit Wiederholung"),
p("Die Elemente dürfen wieder verwendet werden."),
p("$$\\binom{n+k-1}{k}=\\frac{(n+k-1)!}{(n-1)! \\cdot k!}$$"),
h4("Beispiel:"),
p("4 kleine Welpen suchen sich einen Platz unter einem der 6 Stühle."),
p("$n=6, k=4 \\implies \\frac{(6+4-1)!}{(6-1)! \\cdot 4!} = 126$ Möglichkeiten.")
)
)
shiny::withMathJax(
shiny::tabsetPanel(
type = "tabs",
# --- TAB 1: PERMUTATION ---
shiny::tabPanel("Permutation",
shiny::br(),
shiny::h2("Permutation"),
shiny::p("Die Permutation beschäftigt sich mit der Anordnung aller Elemente einer Menge. Bei Permutation unterscheidet man zwei Fälle:"),
htmltools::tags$ul(
htmltools::tags$li(shiny::strong("Permutationen ohne Wiederholung:"), " Sind alle Elemente unterscheidbar (3 Bücher (A, B, C) legen in einem Buchregal, jedes Buch ist einzigartig)."),
htmltools::tags$li(shiny::strong("Permutationen mit Wiederholung:"), " Sind einige Elemente gleich (100 HTW-Studierende werden in 2 Gruppen aufgeteilt: Bachelor und Master, egal was ihre Namen oder Geschlechte sind, solange bleiben die Studierenden innerhalb einer Master-Gruppe, die sind gleich).") ),
shiny::hr(),
shiny::h3("1.1 Permutation ohne Wiederholung"),
shiny::p(shiny::HTML("Alle Elemente sind verschieden/ unterscheidbar, dann gibt es \\(n!\\) verschiedene Anordnungen. \\(n!\\) heißt n Fakultät mit \\(n \\geq 0\\).")),
shiny::p("\\(1! =1\\)"),
shiny::p("\\(2! = 2 \\cdot 1 = 2\\)"),
shiny::p("\\(3! = 3 \\cdot 2 \\cdot 1  =6\\)"),
shiny::p("\\(4!=4 \\cdot 3 \\cdot 2 \\cdot 1 = 24\\)"),
shiny::h4("Beispiele:"),
htmltools::tags$ol(
htmltools::tags$li(
shiny::p("Du hast 5 verschiedene Bücher und möchtest wissen, wie viele Arten kannst Du diese in einem Regal anordnen:"),
shiny::p("Anzahl der Bücher: \\(n=5\\implies n! = 5! =120\\) Möglichkeiten.")
),
htmltools::tags$li(
shiny::p("Acht verschiedene Personen sollen sich beliebig auf acht Stühle verteilen. Wie viele Möglichkeiten zur Anordnung der Personen gibt es?"),
shiny::p("Anzahl der Personen: \\(n=8 \\implies n! =8! =40.320\\) Möglichkeiten.")
),
htmltools::tags$li(
shiny::p("Drei Kinder (A,B,C) stellen sich an einem Eisstand an. Wie viele Möglichkeiten des Anstehens?"),
shiny::p("Anzahl der Kinder: \\(n=3 \\implies n! =3! =6\\) Möglichkeiten.")
)
),
shiny::h4(shiny::strong("Zyklische Permutation")),
shiny::p("Es gibt \\((n-1)!\\) Möglichkeiten, unterscheidbare Objekte in einem Kreis anzuordnen."),
shiny::p("In einer Urne befinden sich 5 verschiedenfarbige Kugeln. Wie viele Möglichkeiten gibt es, die Kugeln ", shiny::em("in einer Reihe"), " anzuordnen?"),
shiny::p("\\(n!=5!=120\\)"),
shiny::p("Wie viele Möglichkeiten gibt es, die Kugeln ", shiny::em("in einem Kreis"), " anzuordnen?"),
shiny::p("\\((n-1)! = (5-1)! = 4! = 24\\)"),
shiny::hr(),
shiny::h3("1.2 Permutation mit Wiederholung"),
shiny::p("Eine Permutation mit Wiederholung ist eine Anordnung von \\(n\\) Objekten, von denen manche nicht unterscheidbar sind."),
shiny::p("$$\\frac{n!}{k_1! \\cdot k_2! \\cdots k_m!}$$"),
shiny::p("\\(n\\): Gesamtzahl der Objekte"),
shiny::p("\\(k\\): Gesamtzahl der identischen Objekte"),
shiny::h4("Beispiele:"),
htmltools::tags$ol(
htmltools::tags$li(
shiny::p("Ein Korb enthält 3 Äpfel und 2 Bananen, wie viele Möglichkeiten gibt es, diese Obst in einer Reihe anzuordnen?"),
shiny::p("\\(n=5\\) (3 Äpfel + 2 Bananen)"),
shiny::p("\\(k_1 =3\\) (Apfel)"),
shiny::p("\\(k_2 =2\\) (Banene)"),
shiny::p("$$\\frac{5!}{3! \\cdot 2!} = 10 \\text{ Möglichkeiten.}$$")
),
htmltools::tags$li(
shiny::p("Du möchtest die Buchstaben des Wortes 'BANANA' anordnen, wie viele Möglichkeiten gibt es?"),
shiny::p("\\(n=6\\)"),
shiny::p("\\(k_1=1\\) (B)"),
shiny::p("\\(k_2=3\\) (A)"),
shiny::p("\\(k_3 =2\\) (N)"),
shiny::p("$$\\frac{6!}{1! \\cdot 2! \\cdot 3!} = 60 \\text{ Möglichkeiten.}$$")
)
)
),
# --- TAB 2: VARIATION ---
shiny::tabPanel("Variation",
shiny::br(),
shiny::h2("Variation"),
shiny::p("Die Variation beschäftigt sich mit der Auswahl und Anordnung von \\(k\\) Elementen aus einer Gesamtmenge von \\(n\\) Elementen, bei der die Reihenfolge eine Rolle spielt."),
shiny::strong("Warum ist die Reihenfolge bei der Variation wichtig?"),
shiny::p("Stell dir vor, 4-stellige Passwort-Nummer (in 10 Nummer von 0 bis 9) werden ausgewählt"),
shiny::p("- 1234 eingegeben -> Das Handy ist entsperrt."),
shiny::p("- 1432 eingegeben -> Eine Warnung auftaucht."),
shiyn::p("Offensichlicht führt die Änderung der Reihefolge der 4-stellige Nummer zu einem neuen Ergebnis. Die Reihefolge spielt daher eine große Bedeutung bei der Variation."),
shiny::p(shiny::strong("Identifizierungstipp:"), " Jede Aufgabe, die Rangfolge (Erster, Zweiter, Dritter), Rollenzuweisung (Bachelor, Master) oder Identifikationsnummer (PIN-Code, ID-Nummer, Handynummer) beinhaltet, ist eine Variationsaufgabe."),
shiny::p("Der Unterschied zwischen mit und ohne Wiederholung liegt auf eine Aktion: ob die ausgewählte Elemente im nächsten Zug erneut ausgewählt werden oder nicht."),
shiny::hr(),
shiny::h3("2.1 Variation mit Wiederholung"),
shiny::p("Die Elemente dürfen wieder verwendet werden und die Elemente im Ergebnis können exakt gleich sein."),
shiny::p("$$n^k$$"),
shiny::h4("Beispiel:"),
shiny::p("Ein Smartphone-PIN besteht aus 4-stelligen Nummerkombination (Ziffern von 0 bis 9)."),
shiny::p("$n=10, k=4 \\implies n^k = 10^4 = 10.000$ Möglichkeiten."),
shiny::hr(),
shiny::h3("2.2 Variation ohne Wiederholung"),
shiny::p("Die gezogenen Elemente werden nicht zurückgelegt."),
shiny::p("$$\\frac{n!}{(n-k)!}$$"),
shiny::h4("Beispiel:"),
shiny::p("In einem Pferderennen hat 20 Pferde. 3 Pferde werden vorausgenommen, die als Erstes, Zweites und Drittes kommen."),
shiny::p("$n=20, k=3 \\implies \\frac{20!}{(20-3)!} = 6.840$ Möglichkeiten.")
),
# --- TAB 3: KOMBINATION ---
shiny::tabPanel("Kombination",
shiny::br(),
shiny::h2("Kombination"),
shiny::p("Die Kombination handelt sich um eine Auswahl von $k$ Elementen, bei der die Reihenfolge ", shiny::em("keine"), " Rolle spielt (z.B. Obstkorb mit Orange, Apfel, Mango)."),
shiny::p(shiny::strong("Identifizierungstipp:"), " Jede Aufgabe, bei der es nur um eine Auswahl oder Gruppenbildung geht (z.B. Lotto, Teambildung...), ohne dass die Positionen der Elemente eine Rolle spielen."),
shiny::hr(),
shiny::h3("3.1 Kombination ohne Wiederholung"),
shiny::p("Die gezogenen Elemente werden nicht zurückgelegt."),
shiny::p("$$\\binom{n}{k} = \\frac{n!}{k!(n-k)!}$$"),
shiny::h4("Beispiel:"),
shiny::p("Die Ziehung von Lotto '6 aus 49'."),
shiny::p("$n=49, k=6 \\implies \\binom{49}{6} = 13.983.816$ Möglichkeiten."),
shiny::hr(),
shiny::h3("3.2 Kombination mit Wiederholung"),
shiny::p("Die Elemente dürfen wieder verwendet werden."),
shiny::p("$$\\binom{n+k-1}{k}=\\frac{(n+k-1)!}{(n-1)! \\cdot k!}$$"),
shiny::h4("Beispiel:"),
shiny::p("4 kleine Welpen suchen sich einen Platz unter einem der 6 Stühle."),
shiny::p("$n=6, k=4 \\implies \\frac{(6+4-1)!}{(6-1)! \\cdot 4!} = 126$ Möglichkeiten.")
))
