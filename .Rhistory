fluidRow(
column(5,
div(style = "background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 12px; padding: 15px; margin-bottom: 15px;",
p(strong("Klicken Sie auf ein Produkt, um es dem Pool hinzuzufügen."), style = "font-size: 11px; font-weight: 700; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;"),
actionButton("add_c", "Coffee (C)   + 1", style = "background-color: #fff7ed; border: 1px solid #ffedd5; color: #c2410c; width: 100%; text-align: left; padding: 10px; margin-bottom: 6px; border-radius: 8px; font-weight: 500;"),
actionButton("add_t", "Tea (T)      + 1", style = "background-color: #f0fdf4; border: 1px solid #dcfce7; color: #15803d; width: 100%; text-align: left; padding: 10px; margin-bottom: 6px; border-radius: 8px; font-weight: 500;"),
actionButton("add_b", "Bakery (B)   + 1", style = "background-color: #fef3c7; border: 1px solid #fde68a; color: #b45309; width: 100%; text-align: left; padding: 10px; margin-bottom: 6px; border-radius: 8px; font-weight: 500;"),
br(), br(),
radioButtons("c5_cond", "Bedingung für Ereignis A wählen:",
choices = list("Sicheres Ereignis (Alle Produkte)" = "all",
"Nur Coffee" = "Coffee",
"Nur Tea" = "Tea",
"Kein Bakery" = "not_Bakery",
"Unmögliches Ereignis" = "none"),
selected = "all")
)
),
column(7,
div(style = "background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 12px; padding: 15px;",
span("Aktuelle Bestellungen (Einzelergebnisse ω) - Klicken zum Entfernen", style = "display: block; font-size: 11px; font-weight: 700; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;"),
uiOutput("pool_display"),
hr(style = "border-top: 1px solid #e5e7eb; margin: 15px 0;"),
span("Mathematische Notation", style = "display: block; font-size: 11px; font-weight: 700; color: #ea580c; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 12px;"),
fluidRow(
column(6, p("Ergebnisraum (Ω)", style = "font-size: 13px; font-weight: 600; margin: 0;")),
column(6, uiOutput("math_omega"))
),
div(style = "margin: 10px 0;"),
fluidRow(
column(6, div(p("Ereignis (A)", style = "font-size: 13px; font-weight: 600; margin: 0;"), uiOutput("event_type_text"))),
column(6, uiOutput("math_a"))
),
div(style = "margin: 10px 0;"),
fluidRow(
column(6, p("Komplementärereignis (Aᶜ)", style = "font-size: 13px; font-weight: 600; margin: 0;")),
column(6, uiOutput("math_ac"))
)
)
)
)
)
